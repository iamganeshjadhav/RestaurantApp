@using RestaurantApp.Models

@{
    var items = ViewBag.Items ?? new List<Item>();
    var cart = ViewBag.Cart ?? new List<CartItem>();
}

<h1>Restaurant Menu</h1>

@if (Context.Session.GetString("User") != null)
{
    <h3>Welcome @Context.Session.GetString("User")</h3>
    <a href="/Account/Logout">Logout</a>
}
else
{
    <a href="/Account/Login">Login</a>
}

<hr />

@foreach (var item in items)
{
    <form method="post" action="/Menu/AddToCart">
        <div style="margin-bottom:15px; border:1px solid #ccc; padding:10px;">
            <h3>@item.Name</h3>
            <p>₹@item.Price</p>

            <input type="hidden" name="id" value="@item.Id" />
            <input type="number" name="qty" value="1" min="1" />

            @if (Context.Session.GetString("User") != null)
            {
                <button type="submit">Add to Cart</button>
            }
            else
            {
                <a href="/Account/Login">Login to Add</a>
            }
        </div>
    </form>
}

<hr />

<h2>Cart</h2>

@if (Context.Session.GetString("User") != null)
{
    <p>User: @Context.Session.GetString("User")</p>
}

@if (cart.Count == 0)
{
    <p>Cart is empty</p>
}
else
{
    <ul>
        @foreach (var c in cart)
        {
            <li>
                @c.Item.Name x @c.Quantity = ₹@c.Total
            </li>
        }
    </ul>
}

<h2>Total: ₹@ViewBag.Total</h2>

<a href="/Menu/ClearCart">Clear Cart</a>